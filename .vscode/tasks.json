{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "backend: run",
			"type": "shell",
			"command": "${workspaceFolder}/tools/apache-maven-3.9.6/bin/mvn.cmd spring-boot:run",
			"options": {
				"cwd": "${workspaceFolder}/backend",
				"env": {
					"JAVA_HOME": "C:/Program Files/Microsoft/jdk-21.0.10.7-hotspot",
					"MAVEN_OPTS": "-Xms256m -Xmx512m"
				}
			},
			"group": "build",
			"presentation": { "panel": "dedicated", "reveal": "always" }
		},
		{
			"label": "backend: build",
			"type": "shell",
			"command": "${workspaceFolder}/tools/apache-maven-3.9.6/bin/mvn.cmd clean package -DskipTests",
			"options": {
				"cwd": "${workspaceFolder}/backend",
				"env": {
					"JAVA_HOME": "C:/Program Files/Microsoft/jdk-21.0.10.7-hotspot"
				}
			},
			"group": "build",
			"presentation": { "panel": "dedicated", "reveal": "always" }
		},
		{
			"label": "frontend: dev",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": { "panel": "dedicated", "reveal": "always" }
		},
		{
			"label": "frontend: build",
			"type": "shell",
			"command": "npm run build",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": { "panel": "dedicated", "reveal": "always" }
		}
	]
}