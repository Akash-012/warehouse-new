# ─────────────────────────────────────────────
# Backend environment variables template
# Set these as system environment variables,
# or export them before running mvn spring-boot:run
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/wms_db?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=

# ── JWT ───────────────────────────────────────
# IMPORTANT: Replace with a strong random secret in production (min 64 chars)
JWT_SECRET=a2c4e6f8h1k3m5n7p9r2s4v6y8z1b3d5g7j9l1o3q5w7e9z1x3c5v7b9m2k4
JWT_EXPIRATION_MS=86400000

# ── Server ────────────────────────────────────
SERVER_PORT=8080

# ── CORS ──────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── JPA / Logging ─────────────────────────────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
DB_POOL_SIZE=20
