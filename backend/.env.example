# ─────────────────────────────────────────────
# Backend environment variables template
# Set these as system environment variables,
# or export them before running mvn spring-boot:run
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Local: jdbc:mysql://localhost:3306/wms_db?createDatabaseIfNotExist=true
# Live:  jdbc:mysql://<db-host>:3306/<db-name>
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# ── JWT ───────────────────────────────────────
# IMPORTANT: Replace with a strong random secret in production (min 64 chars)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# ── Server ────────────────────────────────────
SERVER_PORT=8080

# ── CORS ──────────────────────────────────────
# Local: http://localhost:3000
# Live:  https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=

# ── JPA / Logging ─────────────────────────────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
DB_POOL_SIZE=20

# ── Spring AI (optional) ──────────────────────
# Keep disabled if you don't want Spring AI:
APP_AI_ENABLED=false

# If you want Spring AI, set APP_AI_ENABLED=true and configure provider vars.
# Current dependency in pom.xml uses OpenAI starter:
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_MODEL=gpt-4o-mini

# Optional Ollama notes (if you switch dependency in pom.xml to Ollama starter):
# SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434
# SPRING_AI_OLLAMA_MODEL=llama3.1:8b
